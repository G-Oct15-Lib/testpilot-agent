# Default mode is fully local and does not spend model tokens.
TESTPILOT_AGENT_MODE=mock

# Set TESTPILOT_AGENT_MODE=auto or llm to enable a real OpenAI-compatible model.
# Do not commit a real .env file. .env is ignored by git.
TESTPILOT_LLM_API_KEY=your_api_key_here
TESTPILOT_LLM_BASE_URL=https://api.openai.com/v1
TESTPILOT_LLM_MODEL=gpt-4o-mini
TESTPILOT_LLM_TIMEOUT_SECONDS=35

# Optional: set true if you want API failures to surface instead of falling back to mock.
TESTPILOT_LLM_STRICT=false
